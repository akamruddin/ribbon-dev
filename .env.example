# ============================================================
# Ribbon DevCloud — Docker Compose environment
# Copy to .env and fill in required values before deploying
# ============================================================

# Required — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# Public URL of the app (used for CORS and email links)
APP_URL=http://your-internal-server

# Email — SMTP AUTH must be enabled for this mailbox in M365 admin
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=devexchange@rbbn.com
SMTP_PASS=
EMAIL_FROM=Ribbon DevExchange <devexchange@rbbn.com>
EMAIL_FROM_ADDR=devexchange@rbbn.com

# Optional overrides (defaults shown)
POSTGRES_PASSWORD=ribbondev
HTTP_PORT=80
NODE_ENV=production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Local dev only (not used by Docker Compose) ----
# VITE_API_BASE_URL=http://localhost:8000
