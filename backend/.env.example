# Backend — copy to .env
PORT=8000
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://ribbon:ribbondev@localhost:5432/ribbon_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-before-production
JWT_REFRESH_SECRET=change-me-refresh-before-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173
