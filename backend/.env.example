# Backend — copy to .env
PORT=8000
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://ribbon:ribbondev@localhost:5432/ribbon_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-before-production
JWT_REFRESH_SECRET=change-me-refresh-before-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Lab orchestration
# 64-char hex string for AES-256-GCM credential encryption: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=change-me-64-hex-chars

# OpenStack VM names used by the orchestrator
MUSE_VM_NAME=muse.ipo-strike-muse-001.lab.rbbn.com   # VM name in OpenStack
MUSE_SNAPSHOT_IMAGE_ID=             # Glance image ID for the clean Muse snapshot

# SSH key used to access lab devices (path on the backend server)
LAB_SSH_KEY_PATH=/home/ubuntu/.ssh/muse-key
# LAB_SSH_PASSWORD=                 # fallback if key auth is not available
LAB_SSH_CMD_DELAY_MS=800            # ms between interactive shell commands
